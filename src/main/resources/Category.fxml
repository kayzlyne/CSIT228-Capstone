<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="12"
      style="-fx-background-color:#f5f5dc; -fx-padding:25; -fx-pref-width:400; -fx-pref-height:700;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="Controllers.CategoryController">

    <Label text="Category Manager"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />



    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Category ID" minWidth="100"
               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />

        <TextField fx:id="txtCategoryId"
                   promptText="e.g. 1"
                   style="-fx-background-color:#fffaf0;
                          -fx-border-color:#A0522D;
                          -fx-border-radius:8;
                          -fx-background-radius:8;
                          -fx-border-width:1.5;
                          -fx-padding:10 14;
                          -fx-font-size:13;"
                   HBox.hgrow="ALWAYS" />
    </HBox>



    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Name" minWidth="100"
               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />

        <TextField fx:id="txtCategoryName"
                   promptText="e.g. Food"
                   style="-fx-background-color:#fffaf0;
                          -fx-border-color:#A0522D;
                          -fx-border-radius:8;
                          -fx-background-radius:8;
                          -fx-border-width:1.5;
                          -fx-padding:10 14;
                          -fx-font-size:13;"
                   HBox.hgrow="ALWAYS" />
    </HBox>



    <HBox alignment="TOP_LEFT" spacing="10">
        <Label text="Description" minWidth="100"
               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />

        <TextArea fx:id="txtDescription"
                  promptText="Enter category description"
                  prefRowCount="4"
                  wrapText="true"
                  style="-fx-background-color:#fffaf0;
                         -fx-border-color:#A0522D;
                         -fx-border-radius:8;
                         -fx-background-radius:8;
                         -fx-border-width:1.5;
                         -fx-padding:10 14;
                         -fx-font-size:13;"
                  HBox.hgrow="ALWAYS" />
    </HBox>



    <Button text="Save Category"
            onAction="#handleSaveCategory"
            style="-fx-background-color:#8B4513;
                   -fx-text-fill:white;
                   -fx-font-weight:bold;
                   -fx-background-radius:8;
                   -fx-border-radius:8;
                   -fx-pref-width:280;
                   -fx-pref-height:40;
                   -fx-cursor:hand;" />



    <Button text="Edit Category"
            onAction="#handleEditCategory"
            style="-fx-background-color:#A0522D;
                   -fx-text-fill:white;
                   -fx-font-weight:bold;
                   -fx-background-radius:8;
                   -fx-border-radius:8;
                   -fx-pref-width:280;
                   -fx-pref-height:40;
                   -fx-cursor:hand;" />



    <Button text="Clear"
            onAction="#handleClear"
            style="-fx-background-color:transparent;
                   -fx-text-fill:#8B4513;
                   -fx-font-weight:bold;
                   -fx-border-color:#A0522D;
                   -fx-border-radius:8;
                   -fx-background-radius:8;
                   -fx-pref-width:280;
                   -fx-pref-height:40;
                   -fx-cursor:hand;" />

</VBox>
