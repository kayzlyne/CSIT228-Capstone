<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="Users.EditProfileController"
      alignment="CENTER" spacing="15"
      style="-fx-background-color:#f5f5dc; -fx-padding:30; -fx-pref-width:400; -fx-pref-height:700;">
    <Label text="Update Profile"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>

    <TextField fx:id="nameField" promptText="Name"
               style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-pref-width:280;"/>
    <TextField fx:id="emailField" promptText="Email"
               style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-pref-width:280;"/>
    <PasswordField fx:id="passwordField" promptText="New Password (optional)"
                   style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-pref-width:280;"/>

    <Label fx:id="messageLabel" text="" style="-fx-text-fill:#8B0000;"/>

    <Button text="Save" onAction="#onSaveClick"
            style="-fx-background-color:#8B4513; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-pref-width:280; -fx-pref-height:40;"/>
    <Button text="Cancel" onAction="#onCancelClick"
            style="-fx-background-color:#fffaf0; -fx-text-fill:#4B2E2E; -fx-border-color:#A0522D; -fx-font-weight:bold; -fx-background-radius:8; -fx-border-radius:8; -fx-pref-width:280; -fx-pref-height:40;"/>
</VBox>
