<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="12"
      style="-fx-background-color:#f5f5dc; -fx-padding:25; -fx-pref-width:400; -fx-pref-height:700;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="Controllers.addTransController">

    <Label text="Add Transaction"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Amount" minWidth="100"
               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />
        <TextField fx:id="amountField" promptText="e.g. 150.00"
                   style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-background-radius:8; -fx-border-width:1.5; -fx-padding:10 14; -fx-font-size:13;" HBox.hgrow="ALWAYS" />
    </HBox>



    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Date" minWidth="100"
               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />
        <TextField fx:id="dateField" promptText="YYYY-MM-DD"
                   style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-background-radius:8; -fx-border-width:1.5; -fx-padding:10 14; -fx-font-size:13;" HBox.hgrow="ALWAYS" />
    </HBox>



    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Description" minWidth="100"
               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />
        <TextField fx:id="descriptionField" promptText="e.g. Bought lunch"
                   style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-background-radius:8; -fx-border-width:1.5; -fx-padding:10 14; -fx-font-size:13;" HBox.hgrow="ALWAYS" />
    </HBox>





    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Type" minWidth="100"
               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" />
        <ChoiceBox fx:id="typeChoice"
                   style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
    </HBox>





    <Label fx:id="messageLabel" text=""
           style="-fx-text-fill:#8B0000; -fx-font-size:12;" />

    <Button fx:id="saveBtn" text="Save" onAction="#onSaveClick"
            style="-fx-background-color:#8B4513; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-border-radius:8; -fx-pref-width:280; -fx-pref-height:40; -fx-cursor:hand;" />

    <Button fx:id="backBtn" text="Cancel" onAction="#onBackClick"
            style="-fx-background-color:transparent; -fx-text-fill:#8B4513; -fx-font-weight:bold; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-background-radius:8; -fx-pref-width:280; -fx-pref-height:40; -fx-cursor:hand;" />
</VBox>