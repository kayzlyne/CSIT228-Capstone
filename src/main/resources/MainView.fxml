<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="Controllers.MainViewController"
           style="-fx-background-color:#f5f5dc; -fx-pref-width:400; -fx-pref-height:700;">

    <VBox alignment="TOP_CENTER" spacing="15" style="-fx-padding:20;">
        <HBox alignment="CENTER" spacing="10" style="-fx-background-color:#8B4513; -fx-padding:10; -fx-background-radius:8;">
            <Label text="Expense Tracker"
                   style="-fx-text-fill:white; -fx-font-size:20; -fx-font-weight:bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="P" fx:id="profileBtn" onAction="#onProfileClick"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-font-size:16;"/>
        </HBox>

        <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:350;">
            <Label text="To Pay:" style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>
            <ListView fx:id="toPayList" prefHeight="80"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER">
            <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:160;">
                <Label text="Budget" style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>
                <Label fx:id="weekBudgetLabel" text="Week: PHP 300 / PHP 500" style="-fx-text-fill:#4B2E2E;"/>
                <Label fx:id="monthBudgetLabel" text="Month: PHP 1200 / PHP 3000" style="-fx-text-fill:#4B2E2E;"/>
            </VBox>

            <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:160;">
                <Label text="Spent" style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>
                <Label fx:id="weekSpentLabel" text="Week: PHP 300" style="-fx-text-fill:#4B2E2E;"/>
                <Label fx:id="monthSpentLabel" text="Month: PHP 700" style="-fx-text-fill:#4B2E2E;"/>
            </VBox>
        </HBox>

        <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:350;">
            <Label text="Income to Budget" style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>
            <Label fx:id="incomeLabel" text="PHP 500" style="-fx-font-size:16; -fx-text-fill:#4B2E2E;"/>
        </VBox>

        <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:350;">
            <Label text="Top Spending:" style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>
            <ListView fx:id="topSpendingList" prefHeight="100"/>
        </VBox>

        <PieChart fx:id="spendingChart" prefHeight="180" prefWidth="300"
                  style="-fx-border-color:#A0522D; -fx-border-radius:8;"/>
    </VBox>

    <Button text="+" fx:id="addTransactionFab" onAction="#onAddTransactionClick"
            style="-fx-background-color:#8B4513; -fx-text-fill:white; -fx-font-size:24; -fx-font-weight:bold; -fx-background-radius:50%; -fx-pref-width:50; -fx-pref-height:50;"
            StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets bottom="20" right="20"/>
        </StackPane.margin>
    </Button>
</StackPane>
