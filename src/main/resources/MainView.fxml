<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootPane" style="-fx-background-color:#f5f5dc; -fx-pref-width:400; -fx-pref-height:700;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.MainViewController">

    <VBox alignment="TOP_CENTER" spacing="15" style="-fx-padding:20;">
        <HBox alignment="CENTER" spacing="10" style="-fx-background-color:#8B4513; -fx-padding:10; -fx-background-radius:8;">
            <Label style="-fx-text-fill:white; -fx-font-size:20; -fx-font-weight:bold;" text="Expense Tracker" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="profileBtn" onAction="#onProfileClick" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-font-size:16;" text="P" />
        </HBox>

        <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:350;">
            <Label style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" text="To Pay:" />
            <ListView fx:id="toPayList" prefHeight="80" />
        </VBox>

        <HBox alignment="CENTER" spacing="10">
            <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:160;">
                <Label style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;" text="Budget" />
                <Label fx:id="weekBudgetLabel" style="-fx-text-fill:#4B2E2E;" text="Week: PHP 300 / PHP 500" />
                <Label fx:id="monthBudgetLabel" style="-fx-text-fill:#4B2E2E;" text="Month: PHP 1200 / PHP 3000" />
            </VBox>

            <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:160;">
                <Label style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;" text="Spent" />
                <Label fx:id="weekSpentLabel" style="-fx-text-fill:#4B2E2E;" text="Week: PHP 300" />
                <Label fx:id="monthSpentLabel" style="-fx-text-fill:#4B2E2E;" text="Month: PHP 700" />
            </VBox>
        </HBox>

        <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:350;">
            <Label style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;" text="Income to Budget" />
            <Label fx:id="incomeLabel" style="-fx-font-size:16; -fx-text-fill:#4B2E2E;" text="PHP 500" />
        </VBox>

        <VBox spacing="5" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:10; -fx-pref-width:350;">
            <Label style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;" text="Top Spending:" />
            <ListView fx:id="topSpendingList" prefHeight="100" />
        </VBox>

        <PieChart fx:id="spendingChart" prefHeight="180" prefWidth="300" style="-fx-border-color:#A0522D; -fx-border-radius:8;" />
    </VBox>

    <Button fx:id="plusButton" onAction="#onOptionsClick" style="-fx-background-color:#8B4513; -fx-text-fill:white; -fx-font-size:24; -fx-font-weight:bold; -fx-background-radius:50%; -fx-pref-width:50; -fx-pref-height:50;" text="+" StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets bottom="20" right="20" />
        </StackPane.margin>
    </Button>

    <Pane fx:id="overlay" onMouseClicked="#closeBudgetSheet" style="-fx-background-color: rgba(0,0,0,0.4);" visible="false" />

    <VBox fx:id="budgetSheetContainer" maxHeight="200" maxWidth="180" style="-fx-background-color: transparent;" translateY="500" StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets bottom="70" right="20" />
        </StackPane.margin>
    </VBox>

</StackPane>
