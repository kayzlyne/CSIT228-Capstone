<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color:#f5f5dc; -fx-padding:25; -fx-pref-width:400; -fx-pref-height:700;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="Controllers.AddTransactionController">

    <Label style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;" text="Add Transaction" />

    <TextField fx:id="amountField" promptText="Amount" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-pref-width:280;" />
    <TextField fx:id="dateField" promptText="YYYY-MM-DD" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-pref-width:280;" />
    <ChoiceBox fx:id="typeChoice" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-pref-width:280;" />
    <TextField fx:id="categoryField" promptText="Category" style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-pref-width:280;" />

    <Button fx:id="saveBtn" onAction="#onSaveClick" style="-fx-background-color:#8B4513; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-pref-width:280; -fx-pref-height:40;" text="Save" />

    <Button fx:id="backBtn" onAction="#onBackClick" style="-fx-background-color:transparent; -fx-text-fill:#8B4513; -fx-font-weight:bold;                    -fx-border-color:#A0522D; -fx-border-radius:8; -fx-background-radius:8;                    -fx-pref-width:280; -fx-pref-height:40; -fx-cursor:hand;" text="Cancel" />
</VBox>
