<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="Users.ProfileController"
      alignment="CENTER" spacing="15"
      style="-fx-background-color:#f5f5dc; -fx-padding:30; -fx-pref-width:400; -fx-pref-height:700;">
    <Label text="Profile"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>

    <Label text="Name" style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>
    <Label fx:id="nameLabel" text=""
           style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:8; -fx-pref-width:280;"/>

    <Label text="Email" style="-fx-font-weight:bold; -fx-text-fill:#4B2E2E;"/>
    <Label fx:id="emailLabel" text=""
           style="-fx-background-color:#fffaf0; -fx-border-color:#A0522D; -fx-border-radius:8; -fx-padding:8; -fx-pref-width:280;"/>

    <Label fx:id="messageLabel" text="" style="-fx-text-fill:#8B0000;"/>

    <Button text="Update Profile" onAction="#onUpdateProfileClick"
            style="-fx-background-color:#8B4513; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-pref-width:280; -fx-pref-height:40;"/>
    <Button text="Back" onAction="#onBackClick"
            style="-fx-background-color:#fffaf0; -fx-text-fill:#4B2E2E; -fx-border-color:#A0522D; -fx-font-weight:bold; -fx-background-radius:8; -fx-border-radius:8; -fx-pref-width:280; -fx-pref-height:40;"/>
    <Button text="Logout" onAction="#onLogoutClick"
            style="-fx-background-color:#8B0000; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-pref-width:280; -fx-pref-height:40;"/>
</VBox>
