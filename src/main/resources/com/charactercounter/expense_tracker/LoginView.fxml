<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="10" alignment="CENTER" style="-fx-padding:30;" fx:controller="com.charactercounter.expense_tracker.LoginController">
    <Label text="Login" style="-fx-font-size:16; -fx-font-weight:bold;"/>

    <TextField fx:id="emailField" promptText="Email"/>
    <PasswordField fx:id="passwordField" promptText="Password" />

    <Button text="Login" fx:id="loginBtn" onAction="#onLoginClick"/>
</VBox>
